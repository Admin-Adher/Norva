# Norva - Environment variables
# Copy to .env and fill in your values

# Server
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-in-production

# Supabase (optional - enables cloud device registry, remote pairing, watch history sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Norva Cloud API / Playback
NORVA_CLOUD_API_URL=https://your-project.supabase.co/functions/v1/norva-cloud
ALLOWED_ORIGINS=https://norva-web.example,https://norva-pwa.example
RELAY_TOKEN_SECRET=change-this-to-a-long-random-secret
NORVA_RELAY_BASE_URL=https://relay.norva.example
NORVA_MEDIA_GATEWAY_URL=https://media-gateway.norva.example
NORVA_MEDIA_GATEWAY_TOKEN=change-this-to-a-long-random-secret

# Norva Relay
PUBLIC_BASE_URL=https://relay.norva.example

# Norva Media Gateway
GATEWAY_TOKEN=change-this-to-a-long-random-secret
OUTPUT_DIR=/tmp/norva-media-gateway
FFMPEG_PATH=ffmpeg
# Edge base URL for the account-activity reporter (keeps the provider single-connection
# busy-lock accurate for live-web / long native playback that the edge session/event/
# history writers don't cover). Point at the norva-playback function, e.g.
# https://<supabase-ref>.supabase.co/functions/v1/norva-playback. Leave empty to keep
# the reporter idle (busy-lock still works via the edge-side writers; no regression).
NORVA_EDGE_CALLBACK_BASE=

# Hub identity (auto-detected if not set)
HUB_NAME=Norva Hub
HUB_PUBLIC_URL= # Set if using Cloudflare Tunnel or reverse proxy, e.g. https://xxxx.trycloudflare.com

# Web app CORS (comma-separated origins, e.g. https://norva.tv)
CORS_ORIGINS=

# OIDC SSO (optional)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=

# TMDB (optional - for movie/series metadata)
TMDB_API_KEY=
