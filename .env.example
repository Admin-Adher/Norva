# Norva - Environment variables
# Copy to .env and fill in your values

# Server
PORT=3000
JWT_SECRET=change-this-to-a-random-secret-in-production

# Supabase (optional - enables cloud device registry, remote pairing, watch history sync)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Hub identity (auto-detected if not set)
HUB_NAME=Norva Hub
HUB_PUBLIC_URL= # Set if using Cloudflare Tunnel or reverse proxy, e.g. https://xxxx.trycloudflare.com

# Web app CORS (comma-separated origins, e.g. https://norva-web.vercel.app)
CORS_ORIGINS=

# OIDC SSO (optional)
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_CALLBACK_URL=

# TMDB (optional - for movie/series metadata)
TMDB_API_KEY=
