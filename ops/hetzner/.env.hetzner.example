# =============================================================================
# Norva self-host (Hetzner) — Supabase OSS stack secrets  [PostgreSQL 17]
# Copy to  ops/hetzner/.env  and fill EVERY required value. NEVER commit .env.
# Generate strong secrets:  openssl rand -hex 32   (or  openssl rand -base64 48)
# =============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
# NOTE: POSTGRES_USER is intentionally NOT passed to the db container — the
# supabase/postgres image defaults it to `supabase_admin`, which the init scripts
# use as the owner of _supabase/_realtime/etc. Do NOT set POSTGRES_USER=postgres
# for the db service (that was what broke `role "supabase_admin" does not exist`).
# Superuser password (long, random). Used by the whole stack.
POSTGRES_PASSWORD=CHANGE_ME_long_random

# --- JWT / API keys -----------------------------------------------------------
# JWT secret: >= 32 chars. anon/service keys are JWTs SIGNED with this secret.
# REUSE the managed project's JWT secret + anon/service keys so existing tokens
# keep validating after the cutover.
JWT_SECRET=CHANGE_ME_at_least_32_chars_random
JWT_EXPIRY=3600
ANON_KEY=CHANGE_ME_anon_jwt
SERVICE_ROLE_KEY=CHANGE_ME_service_role_jwt

# --- NEW required secrets (PG17 stack) — generate fresh, box-only -------------
# pg-meta payload encryption key (Studio). Any 32-byte hex:  openssl rand -hex 16
PG_META_CRYPTO_KEY=CHANGE_ME_32_char_key
# Realtime (Phoenix) cookie/session base — MUST be long:  openssl rand -base64 64 | tr -d '\n'
SECRET_KEY_BASE=CHANGE_ME_64_plus_char_random

# --- Public URLs (behind your TLS reverse proxy: Caddy/nginx) -----------------
# Externally reachable API endpoint (Kong). What the app + recreated pg_cron jobs
# call. API_EXTERNAL_URL defaults to this if left unset.
SUPABASE_PUBLIC_URL=https://api.norva.tv
API_EXTERNAL_URL=https://api.norva.tv
SITE_URL=https://norva.tv
# Endpoint the recreated cron jobs hit for edge functions (usually PUBLIC_URL).
FUNCTIONS_BASE_URL=https://api.norva.tv/functions/v1
# Comma-separated extra allowed redirect URLs for GoTrue (optional).
ADDITIONAL_REDIRECT_URLS=

# --- Kong (localhost-bound; Caddy terminates TLS) -----------------------------
KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443

# --- Studio (admin UI) auth ---------------------------------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_long_random
STUDIO_DEFAULT_ORGANIZATION=Norva
STUDIO_DEFAULT_PROJECT=Norva
# Optional: Studio SQL Assistant. Leave empty to disable.
OPENAI_API_KEY=

# --- Auth behaviour toggles (sane defaults; override only if needed) ----------
DISABLE_SIGNUP=false
ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=false
ENABLE_ANONYMOUS_USERS=false
ENABLE_PHONE_SIGNUP=false
ENABLE_PHONE_AUTOCONFIRM=false

# --- PostgREST ----------------------------------------------------------------
PGRST_DB_SCHEMAS=public,storage,graphql_public

# --- Edge functions -----------------------------------------------------------
# The `main` router enforces JWT only when true. Norva functions handle their own
# auth (anon/service key + NORVA_CRON_SHARED_SECRET), matching managed. Keep false.
FUNCTIONS_VERIFY_JWT=false

# --- SMTP (GoTrue auth emails; Norva also uses Resend for product emails) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Norva
SMTP_ADMIN_EMAIL=admin@norva.tv

# --- Edge function secrets (mirror the managed project's function secrets) -----
# App-level secrets the norva-* functions read at runtime. Pull the authoritative
# list from the managed project (Dashboard > Edge Functions > Secrets) — this is a
# REMINDER SET, not exhaustive. Do NOT paste real values into the example file.
NORVA_BACKFILL_TOKEN=
NORVA_CRON_SHARED_SECRET=
# Domain-scoped `sending_access` key for norva.tv. This is the only Resend key
# exposed to the shared Edge runtime and GoTrue SMTP.
RESEND_API_KEY=
# Full-access key for host-side Resend operations only (taxonomy, webhook and
# sending-key rotation). docker-compose MUST NOT forward it to Edge functions.
RESEND_MANAGEMENT_API_KEY=
# Contact records, global unsubscribe and properties are team-wide in Resend.
# Keep false until Norva has a dedicated Resend team (not shared with BuildTrack).
RESEND_CONTACT_PROJECTION_ENABLED=false
RESEND_DEDICATED_TEAM_CONFIRMED=false
# Private worker tuning. Defaults preserve the <=5 minute consent-revocation
# SLO while staying below Resend's documented API rate envelope.
RESEND_CONTACT_BATCH_SIZE=12
RESEND_CONTACT_RECONCILE_BATCH_SIZE=25
RESEND_CONTACT_POLL_SECONDS=60
RESEND_CONTACT_PACING_MS=300
RESEND_CONTACT_API_INTERVAL_MS=300
# Created by Resend for https://api.norva.tv/functions/v1/norva-resend-webhook.
# Never reuse the API key here; this is a separate whsec_ signing secret.
RESEND_WEBHOOK_SECRET=
TMDB_API_KEY=
NORVA_MEDIA_GATEWAY_URL=https://media-gateway.norva.tv
NORVA_MEDIA_GATEWAY_TOKEN=
# Private LID worker origin/token. Keep empty until health is green and the DB
# policy has a future expiry plus an explicitly enabled shadow/canary stage.
# LID_WORKER_TOKEN authenticates the worker itself; NORVA_LID_WORKER_TOKEN is
# forwarded to Edge callers. Set both token variables to the exact same value.
NORVA_LID_WORKER_URL=
NORVA_LID_WORKER_TOKEN=
LID_WORKER_TOKEN=
NORVA_RELAY_BASE_URL=https://relay.norva.tv
RELAY_TOKEN_SECRET=
# Telegram ops channel (same bot as the Netdata box alerts — see monitoring/MONITORING.md).
# Used by edge functions for ops alerts (norva-admin/ops-alert) + support tickets
# (norva-support). Empty = Telegram notifications silently disabled.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Optional single ops mailbox. Empty means ops alerts are Telegram-only. This is
# never inferred from auth.users or admin roles.
NORVA_OPS_EMAIL=
# Billing (inert until set): RevenueCat / Stancer
NORVA_REVENUECAT_WEBHOOK_AUTH=
NORVA_RC_ACCEPT_SANDBOX=false
NORVA_RC_UNKNOWN_PRODUCT_POLICY=error
SEND_EMAIL_HOOK_SECRET=
# Billing / entitlements runtime gate (read by _shared/entitlements.ts). MUST be
# forwarded to the functions container (docker-compose does). Two modes: `observe`
# (access open, billing observed but NOT enforced) and `enforce` (plan limits +
# soft-wall active). PRODUCTION runs `enforce` + BILLING_MODE=revenuecat — the
# Revolut payment rail is LIVE (prod cutover validated 2026-07-11, see
# docs/BILLING-REVOLUT-MIGRATION.md), so non-subscribers soft-wall to the `free`
# tier (browse, no playback) and can subscribe via Revolut. Only drop to `observe`
# for an emergency rollback (reopens everything). Changing this requires RECREATING
# the container (docker compose up -d functions), not restart.
NORVA_ENTITLEMENTS_MODE=enforce
NORVA_BILLING_MODE=revenuecat
# Lifecycle billing emails (norva-lifecycle). MASTER switch + per-flow flags — leave
# ALL false until a flow is ready. Dunning is Revolut-scoped + safe; NEVER enable
# EXPIRE without DUNNING (cuts users off with no warning email); trial reminders
# are exclusively owned by the provider-correct DB J-3/J-1 jobs; winback/abandoned
# additionally require an explicit per-user opt-in,
# the registered postal address and the HMAC secret below.
# Changing any of these requires RECREATING the container (docker compose up -d functions).
NORVA_LIFECYCLE_BILLING_LIVE=false
NORVA_LC_DUNNING=false
NORVA_LC_EXPIRE=false
NORVA_LC_WINBACK=false
NORVA_LC_ABANDONED=false
# Physical postal address for the email footer (CAN-SPAM). Required before marketing email.
NORVA_POSTAL_ADDRESS=
# Stable random HMAC key for signed RFC8058 one-click unsubscribe links.
# Generate once with: openssl rand -hex 32
NORVA_LIFECYCLE_UNSUBSCRIBE_SECRET=
# Required for audience consent reconciliation. Keep environment-specific so a
# staging deployment can never mutate the production Resend audience.
# FCM push: Firebase service-account JSON on ONE line (read by _shared/fcm.ts).
FCM_SERVICE_ACCOUNT=
# Revolut Merchant billing (SANDBOX during dev; swap to production keys at cutover).
# REVOLUT_SECRET_KEY = the API secret key (sk_...). REVOLUT_WEBHOOK_SIGNING_SECRET =
# the wsk_... returned when you create the webhook (POST /api/1.0/webhooks).
REVOLUT_SECRET_KEY=
REVOLUT_WEBHOOK_SIGNING_SECRET=

# --- Storage ------------------------------------------------------------------
# 'file' = local disk (simplest). STORAGE_BACKEND_PATH must be on the NVMe mount.
STORAGE_BACKEND=file
STORAGE_BACKEND_PATH=/var/lib/norva/storage

# --- Migration source (the managed project we're dumping FROM) ----------------
# Used only by scripts/01-dump-prod.sh. Get the direct (5432) connection string
# from Supabase Dashboard > Project Settings > Database. Keep it out of git.
MANAGED_DB_URL=postgresql://postgres:CHANGE_ME@db.oupsceccxsonaalhueff.supabase.co:5432/postgres
MANAGED_PROJECT_REF=oupsceccxsonaalhueff

# --- Monitoring (Netdata) -----------------------------------------------------
# Password for the read-only `netdata` DB role used by the go.d postgres
# collector. Create the role with monitoring/setup-netdata-pg-role.sql (which
# reads this same value). Box-only secret, generate fresh: openssl rand -hex 24
NETDATA_PG_PASSWORD=CHANGE_ME_long_random
