# =============================================================================
# Norva self-host (Hetzner) — Supabase OSS stack secrets
# Copy to  ops/hetzner/.env  and fill EVERY value. NEVER commit the filled file.
# Generate strong secrets:  openssl rand -hex 32   (or  openssl rand -base64 48)
# =============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=postgres
POSTGRES_USER=postgres
# Superuser password (long, random). Used by the whole stack.
POSTGRES_PASSWORD=CHANGE_ME_long_random

# --- JWT / API keys -----------------------------------------------------------
# JWT secret: >= 32 chars. anon/service keys are JWTs SIGNED with this secret.
# Generate the keys after setting JWT_SECRET, e.g. with supabase's key generator
# or https://supabase.com/docs/guides/self-hosting/docker#generate-api-keys
JWT_SECRET=CHANGE_ME_at_least_32_chars_random
ANON_KEY=CHANGE_ME_anon_jwt
SERVICE_ROLE_KEY=CHANGE_ME_service_role_jwt

# --- Public URLs (behind your TLS reverse proxy) ------------------------------
# The externally reachable API endpoint (Kong). This is what the app + the
# recreated pg_cron jobs will call. Replace with your real domain.
SUPABASE_PUBLIC_URL=https://api.norva.example
SITE_URL=https://norva.example
# Endpoint the recreated cron jobs hit for edge functions (usually PUBLIC_URL).
FUNCTIONS_BASE_URL=https://api.norva.example/functions/v1

# --- Studio (admin UI) auth ---------------------------------------------------
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=CHANGE_ME_long_random

# --- SMTP (GoTrue auth emails; Norva also uses Resend for product emails) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SENDER_NAME=Norva
SMTP_ADMIN_EMAIL=admin@norva.example

# --- Edge function secrets (mirror the managed project's function secrets) -----
# These are the app-level secrets the norva-* functions read at runtime. Pull the
# authoritative list from the managed project (Dashboard > Edge Functions >
# Secrets) — this is a REMINDER SET, not exhaustive. Do NOT paste real values here.
NORVA_BACKFILL_TOKEN=
NORVA_CRON_SHARED_SECRET=
RESEND_API_KEY=
TMDB_API_KEY=
NORVA_MEDIA_GATEWAY_URL=https://media-gateway.norva.example
NORVA_MEDIA_GATEWAY_TOKEN=
NORVA_RELAY_BASE_URL=https://relay.norva.example
RELAY_TOKEN_SECRET=
# Billing (inert until set): RevenueCat / Stancer
NORVA_REVENUECAT_WEBHOOK_AUTH=
STANCER_SECRET_KEY=
SEND_EMAIL_HOOK_SECRET=

# --- Storage ------------------------------------------------------------------
# 'file' = local disk (simplest). Point STORAGE_BACKEND_PATH at the SSD mount.
STORAGE_BACKEND=file
STORAGE_BACKEND_PATH=/var/lib/norva/storage

# --- Migration source (the managed project we're dumping FROM) ----------------
# Used only by scripts/01-dump-prod.sh. Get the pooler/direct connection string
# from Supabase Dashboard > Project Settings > Database. Keep it out of git.
MANAGED_DB_URL=postgresql://postgres:CHANGE_ME@db.oupsceccxsonaalhueff.supabase.co:5432/postgres
MANAGED_PROJECT_REF=oupsceccxsonaalhueff
