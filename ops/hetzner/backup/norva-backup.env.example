# =============================================================================
# /etc/norva-backup.env — self-host backup settings (box-only, root:root 600)
#   sudo cp norva-backup.env.example /etc/norva-backup.env
#   sudo chmod 600 /etc/norva-backup.env && sudo nano /etc/norva-backup.env
# NEVER commit the filled file. The R2 credentials are the same kind used by the
# managed-DB GitHub workflow (an R2 API token with read/write on the bucket).
# =============================================================================

# --- Cloudflare R2 (S3 API) ---------------------------------------------------
R2_ACCOUNT_ID=CHANGE_ME
R2_ACCESS_KEY_ID=CHANGE_ME
R2_SECRET_ACCESS_KEY=CHANGE_ME
R2_BUCKET=norva-db-backups
# Key prefixes inside the bucket (self-host lives beside the managed 'db/' dumps)
R2_PREFIX_DUMPS=selfhost/dumps
R2_PREFIX_WAL=selfhost/wal
R2_PREFIX_BASE=selfhost/base

# --- Local paths / stack ------------------------------------------------------
# ops/hetzner checkout on the box (where .env with POSTGRES_PASSWORD lives)
NORVA_OPS_DIR=/home/adrien/norva/ops/hetzner
WAL_ARCHIVE_DIR=/var/lib/norva/wal-archive
BACKUP_STAGE_DIR=/var/lib/norva/backups
PG_IMAGE=supabase/postgres:17.6.1.136

# --- Retention ------------------------------------------------------------------
KEEP_DUMPS_DAYS=14        # nightly logical dumps on R2
KEEP_BASE_COUNT=8         # weekly base backups on R2 (~2 months)
KEEP_WAL_DAYS=35          # WAL on R2 (must cover the oldest base backup you keep)
KEEP_LOCAL_WAL_DAYS=3     # local WAL copies already uploaded
