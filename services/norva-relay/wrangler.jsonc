{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "norva-relay",
  "main": "src/index.js",
  "compatibility_date": "2026-06-13",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "head_sampling_rate": 0.1
  },
  "vars": {
    "ALLOWED_ORIGINS": "https://norva-eight.vercel.app,https://norva-pgkk.vercel.app"
  }
}
